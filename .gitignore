# tomespire-website
# Hugo + webpack + npm. static/styles.css, static/bundle.js, and static/fonts/
# are committed build outputs (Hugo serves them directly). public/ is the Hugo
# render output and is regenerated on every build. Global gitignore (~/.gitignore)
# handles .claude/ and .private-journal/.

# npm
node_modules/

# Hugo
/public/
/resources/_gen/
.hugo_build.lock

# Cloudflare Wrangler local state
.wrangler/

# Sass / build caches
.sass-cache/
*.css.map
*.scss.map
.npm
.eslintcache
.stylelintcache

# Impeccable (design tooling: critique snapshots and live-mode state — local only)
.impeccable/
.impeccable-live/

# Python (scripts/ generators and their tests)
__pycache__/
*.pyc
.pytest_cache/

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.local
.env.*.local

# Deploy leak-gate patterns (real-identity strings; never published)
.deploy-guard/

# macOS
.DS_Store
._*
Icon[
]

# Claude Code (override global ~/.gitignore that ignores .claude/ entirely;
# track shared project config but keep personal settings local)
!.claude/
.claude/settings.local.json

# Test site.
/testsite/